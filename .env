# Pinned versions for the Spark RTM vs Flink benchmark.
# Sourced by the bench/*.sh scripts and referenced by docker-compose files.

# --- Engines ---
SPARK_IMAGE=apache/spark:4.1.2-scala2.13-java17-ubuntu
SPARK_VERSION=4.1.2
SPARK_SCALA_BINARY=2.13
FLINK_IMAGE=flink:2.2.0-scala_2.12-java17
FLINK_VERSION=2.2.0

# --- Kafka (KRaft, no ZooKeeper) ---
KAFKA_IMAGE=apache/kafka:4.1.0
KAFKA_VERSION=4.1.0
# In-cluster bootstrap (containers talk to each other on the compose network):
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
# Host bootstrap (producer/consumer run on the host):
KAFKA_BOOTSTRAP_HOST=localhost:29092

# --- Topics ---
INPUT_TOPIC=input-events
OUTPUT_TOPIC=output-events
# Capped to 6 across the whole benchmark: 6 partitions, parallelism 6 on every engine,
# so local mirrors the EKS p6 matrix (engine-vs-engine fairness within each environment).
TOPIC_PARTITIONS=6

# --- Load profile ---
TARGET_RATE=10000          # events/second
WARMUP_SECONDS=15
RUN_SECONDS=300

# --- Spark RTM ---
# Trigger duration = RTM's checkpoint cadence. Matched to EKS (60s) so local and cloud share
# the same checkpoint config; the comparison is checkpoint-to-checkpoint on both engines.
RTM_TRIGGER="60 seconds"
# Flink local checkpoint interval (ms), matched to the 60s RTM cadence. 0 = off.
FLINK_CHECKPOINT_MS=60000
